{
  "name": "modushare-windows",
  "version": "1.2.0",
  "description": "ModuShare Desktop client (Electron)",
  "main": "dist/electron/main.js",
  "scripts": {
    "dev": "tsc && electron dist/electron/main.js",
    "build:tsc": "tsc",
    "build": "tsc && electron-builder",
    "build:win": "tsc && electron-builder --win",
    "build:mac": "tsc && electron-builder --mac",
    "make-icons": "electron-icon-builder --input=assets/icon.svg --output=assets"
  },
  "dependencies": {
    "axios": "^1.6.8",
    "electron-store": "^8.1.0",
    "uuid": "^9.0.1",
    "ws": "^8.17.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "@types/uuid": "^9.0.8",
    "@types/ws": "^8.5.10",
    "electron": "^30.0.1",
    "electron-builder": "^24.13.3",
    "electron-icon-builder": "^2.0.1",
    "typescript": "^5.4.5"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/extory/modushare"
  },
  "build": {
    "appId": "co.extory.modushare",
    "productName": "ModuShare",
    "copyright": "Copyright © 2025 Extory",
    "publish": null,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "renderer/**/*",
      "assets/**/*"
    ],
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "icon": "assets/icons/win/icon.ico"
    },
    "mac": {
      "target": [{ "target": "zip", "arch": ["x64"] }],
      "icon": "assets/icons/mac/icon.icns",
      "category": "public.app-category.productivity",
      "gatekeeperAssess": false
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "deleteAppDataOnUninstall": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "guid": "co.extory.modushare"
    },
    "dmg": {
      "title": "ModuShare"
    }
  }
}
