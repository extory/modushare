# ModuShare 환경변수 설정
# 이 파일을 .env 로 복사한 후 값을 채워주세요

# 필수: JWT 서명 비밀키 (openssl rand -hex 32 로 생성)
JWT_SECRET=your-super-secret-key-change-this

# 서버 포트 (docker-compose 에서 자동 설정됨)
# 로컬 개발용 포트 (groupware가 3000/3001 사용 중이므로 3010 사용)
PORT=3010

# CORS 허용 출처
CORS_ORIGIN=https://modushare.extory.co

# 선택: 클립보드 최대 크기 (MB, 기본값 5)
MAX_CLIPBOARD_SIZE_MB=5

# Google OAuth (Google Cloud Console에서 발급)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
